<%- include('_head', { title: 'Reservations' }) %>

<form class="row g-2 align-items-end mb-3" method="get" action="/admin/reservations">
  <div class="col-auto">
    <label class="form-label small mb-0" for="status">Status</label>
    <select class="form-select form-select-sm" id="status" name="status">
      <option value="">All</option>
      <% for (const s of Object.keys(badge)) { %>
        <option value="<%= s %>" <%= filter.status === s ? 'selected' : '' %>><%= s %></option>
      <% } %>
    </select>
  </div>
  <div class="col-auto">
    <label class="form-label small mb-0" for="date">Date</label>
    <input class="form-control form-control-sm" type="date" id="date" name="date" value="<%= filter.date || '' %>">
  </div>
  <div class="col-auto">
    <button class="btn btn-sm btn-primary" type="submit">Filter</button>
    <a class="btn btn-sm btn-outline-secondary" href="/admin/reservations">Reset</a>
  </div>
</form>

<% if (rows.length === 0) { %>
  <p class="text-muted">No reservations found.</p>
<% } else { %>
  <table class="table table-hover small">
    <thead>
      <tr>
        <th>#</th><th>Customer</th><th>Table</th><th>Date</th>
        <th>Slot</th><th>Party</th><th>Remarks</th><th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% for (const r of rows) { %>
        <tr>
          <td><%= r.id %></td>
          <td>
            <%= r.customer_name %><br>
            <span class="text-muted"><%= r.customer_email %></span>
          </td>
          <td><%= r.table_number %></td>
          <td><%= r.reservation_date %></td>
          <td><%= r.time_slot %></td>
          <td><%= r.party_size %></td>
          <td class="text-truncate" style="max-width: 16rem;" title="<%= r.remarks %>"><%= r.remarks %></td>
          <td><span class="badge text-bg-<%= badge[r.status] %>"><%= r.status %></span></td>
        </tr>
      <% } %>
    </tbody>
  </table>
<% } %>

<%- include('_foot') %>
