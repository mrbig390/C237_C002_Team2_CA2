<%- include('_head', { title: 'Tables' }) %>

<% if (rows.length === 0) { %>
  <p class="text-muted">No tables found.</p>
<% } else { %>
  <table class="table table-hover small">
    <thead>
      <tr><th>#</th><th>Table No.</th><th>Capacity</th><th>Location</th></tr>
    </thead>
    <tbody>
      <% for (const t of rows) { %>
        <tr>
          <td><%= t.id %></td>
          <td><%= t.table_number %></td>
          <td><%= t.capacity %></td>
          <td><%= t.location %></td>
        </tr>
      <% } %>
    </tbody>
  </table>
<% } %>

<%- include('_foot') %>
