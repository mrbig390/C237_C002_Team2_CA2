<%- include('../_head', { title: 'Edit Reservation' }) %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h5>Edit Reservation #<%= reservation.id %></h5>
        <small class="text-muted">Table <%= reservation.table_number %> on <%= reservation.reservation_date %></small>
      </div>
      <div class="card-body">
        <form action="/user/reservations/<%= reservation.id %>/update" method="POST">
          
          <div class="mb-2">
            <label class="form-label small">Select Table</label>
            <select class="form-select form-select-sm" name="table_id" required>
              <% availableTables.forEach(table => { %>
                <option value="<%= table.id %>" <%= table.id === reservation.table_id ? 'selected' : '' %>>
                  Table <%= table.table_number %> (Capacity: <%= table.capacity %>)
                </option>
              <% }) %>
            </select>
          </div>
          
          <div class="mb-2">
            <label class="form-label small">Party Size</label>
            <input type="number" class="form-control form-control-sm" name="party_size" 
                   value="<%= reservation.party_size %>" min="1" max="20" required>
          </div>
          
          <div class="mb-2">
            <label class="form-label small">Date</label>
            <input type="date" class="form-control form-control-sm" name="reservation_date" 
                   value="<%= reservation.reservation_date %>" min="<%= new Date().toISOString().split('T')[0] %>" required>
          </div>
          
          <div class="mb-2">
            <label class="form-label small">Time Slot</label>
            <select class="form-select form-select-sm" name="time_slot" required>
              <option value="17:00" <%= reservation.time_slot === '17:00' ? 'selected' : '' %>>5:00 PM</option>
              <option value="17:30" <%= reservation.time_slot === '17:30' ? 'selected' : '' %>>5:30 PM</option>
              <option value="18:00" <%= reservation.time_slot === '18:00' ? 'selected' : '' %>>6:00 PM</option>
              <option value="18:30" <%= reservation.time_slot === '18:30' ? 'selected' : '' %>>6:30 PM</option>
              <option value="19:00" <%= reservation.time_slot === '19:00' ? 'selected' : '' %>>7:00 PM</option>
              <option value="19:30" <%= reservation.time_slot === '19:30' ? 'selected' : '' %>>7:30 PM</option>
              <option value="20:00" <%= reservation.time_slot === '20:00' ? 'selected' : '' %>>8:00 PM</option>
              <option value="20:30" <%= reservation.time_slot === '20:30' ? 'selected' : '' %>>8:30 PM</option>
              <option value="21:00" <%= reservation.time_slot === '21:00' ? 'selected' : '' %>>9:00 PM</option>
              <option value="21:30" <%= reservation.time_slot === '21:30' ? 'selected' : '' %>>9:30 PM</option>
            </select>
          </div>
          
          <div class="mb-3">
            <label class="form-label small">Special Remarks</label>
            <input type="text" class="form-control form-control-sm" name="remarks" 
                   value="<%= reservation.remarks || '' %>" placeholder="Dietary restrictions, special requests...">
          </div>
          
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm">Update Reservation</button>
            <a href="/user/dashboard" class="btn btn-secondary btn-sm">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../_foot') %>
