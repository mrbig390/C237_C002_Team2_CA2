<!-- Login page for both user and admin accounts. -->

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Login</title>
</head>

<body>
    <main>
        <h1>Login</h1>

        <% if (error) { %>
            <p role="alert"><%= error %></p>
        <% } %>

        <form method="post" action="/login">
            <label>
                Email
                <input
                    type="email"
                    name="email"
                    value="<%= email %>"
                    required
                    autocomplete="email"
                >
            </label>

            <br>

            <label>
                Password
                <input
                    type="password"
                    name="password"
                    required
                    autocomplete="current-password"
                >
            </label>

            <br>

            <button type="submit">Login</button>
        </form>

        <p>Need an account? <a href="/register">Register</a></p>
    </main>
</body>
</html>
